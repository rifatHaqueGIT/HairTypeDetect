# ── Databricks & MLflow Configuration ────────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# These are only needed for remote MLflow tracking and Databricks sync.
# Without them, MLflow uses local file-based tracking (./mlruns/).
#

# Databricks workspace URL (e.g. https://your-workspace.cloud.databricks.com)
DATABRICKS_HOST=

# Databricks personal access token (starts with dapi...)
DATABRICKS_TOKEN=

# MLflow tracking URI
# - Set to "databricks" to use Databricks-hosted MLflow
# - Leave empty or remove to use local file-based tracking
# MLFLOW_TRACKING_URI=databricks
